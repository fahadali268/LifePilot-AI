{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "Represents an individual task registered by the user",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the task"
        },
        "description": {
          "type": "string",
          "description": "Detailed notes about the task"
        },
        "deadline": {
          "type": "string",
          "format": "date-time",
          "description": "Target completion date/time"
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Execution priority level"
        },
        "estimatedHours": {
          "type": "number",
          "description": "Estimated duration in hours"
        },
        "completed": {
          "type": "boolean",
          "description": "Status of completion"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Completion timestamp"
        },
        "userId": {
          "type": "string",
          "description": "Owner of the task document"
        }
      },
      "required": ["title", "deadline", "priority", "estimatedHours", "completed", "createdAt", "userId"]
    }
  },
  "firestore": {
    "tasks": {
      "schema": {
        "$ref": "#/entities/Task"
      },
      "description": "Global collection containing all registered task entries"
    }
  }
}
