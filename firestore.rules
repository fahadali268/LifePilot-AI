rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to tasks, ai_analysis, schedules, and chat_history
    match /tasks/{taskId} {
      allow read, write: if true;
    }
    match /ai_analysis/{analysisId} {
      allow read, write: if true;
    }
    match /schedules/{scheduleId} {
      allow read, write: if true;
    }
    match /chat_history/{chatId} {
      allow read, write: if true;
    }
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
